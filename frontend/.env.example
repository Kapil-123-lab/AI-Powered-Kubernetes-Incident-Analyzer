# Copy this file to .env in the SAME folder, then fill in the real value.
# Must match the API_KEY in backend/.env exactly.

API_KEY=

# NOTE: BACKEND_URL is set directly in docker-compose.yml when running
# via Docker Compose (it points to the "backend" service by name).
# Only needed here if running app.py directly without Docker:
# BACKEND_URL=http://127.0.0.1:8000
