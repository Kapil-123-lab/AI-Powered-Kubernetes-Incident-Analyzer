# Copy this file to .env in the SAME folder, then fill in real values.
# This .env is loaded automatically by docker-compose (env_file directive)
# AND by load_dotenv() if you run main.py directly without Docker.

# ── Required ────────────────────────────────────────────────
API_KEY=

# ── Optional alerting ───────────────────────────────────────
SLACK_WEBHOOK_URL=
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# ── Optional Jira auto-ticketing ────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS

# ── Scheduler ────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=30

# NOTE: MONGO_URI, OLLAMA_HOST, PROMETHEUS_URL, and KUBECONFIG are
# set directly in docker-compose.yml's `environment:` block for the
# Docker-networked values, and don't need to go here when running
# via Docker Compose. They only matter if you run main.py directly
# on your machine without Docker — in that case, uncomment and set:
# MONGO_URI=mongodb://localhost:27017
# OLLAMA_HOST=http://localhost:11434
# PROMETHEUS_URL=http://localhost:9090
